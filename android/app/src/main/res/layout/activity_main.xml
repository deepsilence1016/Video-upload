<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    tools:context=".presentation.MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="🤖"
            android:textSize="64sp"
            android:gravity="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Vision Agent"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="v1.0.0-alpha"
            android:textColor="#888888"
            android:textSize="13sp"/>

        <!-- Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AGENT STATUS"
                android:textColor="#00C853"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="⏸ Idle — Tap START to begin"
                android:textColor="#FFFFFF"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tv_state"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="State: IDLE"
                android:textColor="#888888"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tv_session"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Session: —"
                android:textColor="#888888"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tv_fps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="FPS: —"
                android:textColor="#888888"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tv_frames"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Frames: —"
                android:textColor="#888888"
                android:textSize="13sp"/>

        </LinearLayout>

        <!-- START Button -->
        <Button
            android:id="@+id/btn_start"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="▶  START AGENT"
            android:textColor="#000000"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="#00C853"
            android:stateListAnimator="@null"/>

        <!-- STOP Button -->
        <Button
            android:id="@+id/btn_stop"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="■  STOP AGENT"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="#B71C1C"
            android:enabled="false"
            android:stateListAnimator="@null"/>

        <!-- Permissions Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PERMISSIONS"
                android:textColor="#FFA000"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_perm_overlay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="⬜  Display over other apps"
                android:textColor="#AAAAAA"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tv_perm_accessibility"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="⬜  Accessibility service"
                android:textColor="#AAAAAA"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tv_perm_projection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="⬜  Screen capture"
                android:textColor="#AAAAAA"
                android:textSize="14sp"/>

        </LinearLayout>

        <!-- Info Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="40dp"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ABOUT"
                android:textColor="#2979FF"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Vision Agent is an AI-powered screen automation framework.\n\n• OpenCV — real-time vision\n• Tesseract — on-device OCR\n• Rust engine — high-speed frame pipeline\n• FastAPI backend — cloud AI"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
